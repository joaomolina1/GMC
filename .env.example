# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://wnhojvxnamxmpmdislcl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Alternativa (nova API Supabase): cole aqui o valor sb_secret_...
# SUPABASE_SECRET_KEY=

# AI
ANTHROPIC_API_KEY=

# Phase 2 — Embeddings (Voyage AI, 1536-dim vectors)
# Without this key, falls back to pseudo-embeddings (dev only)
VOYAGE_API_KEY=

# Phase 6 — Enterprise (Entra ID SSO)
# Enable Microsoft login button on /login
NEXT_PUBLIC_ENTRA_ENABLED=false
# Azure AD tenant ID (optional — restricts to your org)
AZURE_AD_TENANT_ID=
# Comma-separated allowed email domains for SSO
ENTRA_ALLOWED_DOMAINS=mediacapital.pt,grupomediacapital.pt
# Restrict email/password signup to ENTRA_ALLOWED_DOMAINS (auto-on when Entra enabled)
NEXT_PUBLIC_SIGNUP_DOMAIN_RESTRICT=false
